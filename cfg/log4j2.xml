<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="DEBUG">

    <Appenders>

        <!-- Console Output -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger - %msg%n"/>
        </Console>

        <!-- General Application Log -->
        <RollingFile name="AppFile"
                     fileName="logs/app.log"
                     filePattern="logs/app-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger - %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
        </RollingFile>

        <!-- ISO Messages Log (VERY IMPORTANT) -->
        <RollingFile name="IsoFile"
                     fileName="logs/iso.log"
                     filePattern="logs/iso-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} | %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
        </RollingFile>

        <!-- Error Log -->
        <RollingFile name="ErrorFile"
                     fileName="logs/error.log"
                     filePattern="logs/error-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger - %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
        </RollingFile>

    </Appenders>

    <Loggers>

        <!-- jPOS Core -->
        <Logger name="org.jpos" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AppFile"/>
        </Logger>

        <!-- ISO Messages (increase visibility) -->
        <Logger name="org.jpos.iso" level="DEBUG" additivity="false">
            <AppenderRef ref="IsoFile"/>
            <AppenderRef ref="Console"/>
        </Logger>

        <!-- MUX / Channel -->
        <Logger name="org.jpos.q2.iso" level="DEBUG" additivity="false">
            <AppenderRef ref="AppFile"/>
            <AppenderRef ref="Console"/>
        </Logger>

        <!-- Your Switch Code -->
        <Logger name="com.qswitch" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AppFile"/>
        </Logger>

        <!-- Errors -->
        <Root level="ERROR">
            <AppenderRef ref="ErrorFile"/>
            <AppenderRef ref="Console"/>
        </Root>

    </Loggers>

</Configuration>